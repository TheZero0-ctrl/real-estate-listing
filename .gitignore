# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# frontend dependencies
/frontend/node_modules
/frontend/.pnp
/frontend/.pnp.*
/frontend/.yarn/*
!/frontend/.yarn/patches
!/frontend/.yarn/plugins
!/frontend/.yarn/releases
!/frontend/.yarn/versions

# frontend testing
/frontend/coverage

# next.js
/frontend/.next/
/frontend/out/

# production
/frontend/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
/frontend/.vercel

# typescript
*.tsbuildinfo
/frontend/next-env.d.ts

# rails backend

# Ignore all environment files.
/backend/.env*

/backend/.bundle
/backend/log/*
!/backend/log/.keep
/backend/tmp/*
!/backend/tmp/.keep

# Ignore pidfiles, but keep the directory.
/backend/tmp/pids/*
!/backend/tmp/pids/
!/backend/tmp/pids/.keep

/backend/storage/*
!/backend/storage/.keep
/backend/public/assets
/backend/public/packs
/backend/public/packs-test
/backend/node_modules
/backend/vendor/bundle
/backend/db/*.sqlite3
/backend/db/*.sqlite3-*
/backend/config/master.key

/backend/app/assets/builds/*
!/backend/app/assets/builds/.keep

/backend/node_modules
